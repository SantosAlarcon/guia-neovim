---
import Layout from "../layouts/Layout.astro";
import LogoNeovim from "../components/LogoNeovim.astro";

const postJSONLd = {
    "@context": "https://schema.org",
    "@type": "Thing",
    name: "Inicio | Guía Neovim",
    url: Astro.url,
};
---

<Layout title="Inicio | Guía Neovim">
    <main class="main__container">
        <LogoNeovim height="330" />
        <h1>¿Qué es Neovim?</h1>
        <p>
            <b>Neovim</b> es un editor de textos muy potente y <b
                >multiplataforma</b
            >, basado en el mítico <b>Vim</b>, pero mucho más extensible, y con
            soporte del lenguaje <b>Lua</b>.
        </p>

        <h2>¿Y de qué va esta guía?</h2>
        <p>
            Si alguna vez has tratado de utilizar este editor, y no has podido
            salir de él, no te preocupes. Con esta guía podrás dominar este
            editor de una forma fácil y muy sencilla. Abarcará desde los atajos
            de teclado hasta los diferentes plugins importantes.
        </p>
        <div class="main__botones" role="navigation" aria-label="Navegación principal">
            <a href="/instalacion" tabindex="0">Instalación</a>
            <a href="/atajos" tabindex="0">Atajos</a>
            <a href="/comandos" tabindex="0">Comandos</a>
            <a href="/configuracion" tabindex="0">Configuración</a>
            <a href="/plugins" tabindex="0">Plugins</a>
            <a href="/configuraciones-neovim" tabindex="0"
                >Configuraciones de Neovim</a
            >
			<a href="/lsp" tabindex="0">LSP</a>
        </div>
        <p class="keyboard-hint">
            <kbd>Tab</kbd> para navegar, <kbd>Enter</kbd> para seleccionar
        </p>
    </main>
</Layout>

<style>
    .main__container {
		width: 100%;
        margin: auto;
		font-size: clamp(1rem, 2vw, 1.25rem);
        text-align: center;
		transition: none;
		padding: 4rem 0;
	}

    .main__botones {
        margin-top: 2em;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        color: var(--dark-fg);

        gap: 1.5em;

        @media (width < 720px) {
            flex-direction: column;
            width: 100%;
        }

        & a,
        & a:visited {
            color: inherit;
            text-decoration: none;
            background-color: var(--color-primary);
            padding: 0.5em 1em;
            border-radius: 1em;
            box-shadow:
                0 0.25em 1.5em var(--color-primary-shadow),
                0 0.25em 1.5em var(--color-primary-shadow);
            transition: all 0.3s ease-in-out;
        }

        & a:hover {
            background-color: var(--color-primary-hover);
            box-shadow:
                0 0.25em 1.5em var(--color-primary-shadow-hover),
                0 0.25em 1.5em var(--color-primary-shadow-hover);
        }
    }

    h1 {
        font-size: 4rem;
        font-weight: 700;
        line-height: 1;
        text-align: center;
        margin-bottom: 1em;
    }

    .keyboard-hint {
        margin-top: 3.5em;
        font-size: 1rem;
        opacity: 0.75;
        color: var(--dark-fg);
    }

    .main__botones a:focus {
        outline: 3px solid var(--color-secondary);
        outline-offset: 3px;
    }
</style>

<script>
    const links = document.querySelectorAll('.main__botones a');
    
    document.addEventListener('keydown', (e) => {
        const target = e.target;
        if (!links.includes(target)) return;
        
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
            e.preventDefault();
            const next = target.nextElementSibling;
            if (next) next.focus();
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            e.preventDefault();
            const prev = target.previousElementSibling;
            if (prev) prev.focus();
        }
    });
</script>

<script type="application/ld+json" set:html={JSON.stringify(postJSONLd)}>
</script>
